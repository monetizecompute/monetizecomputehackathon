# All optional. Anything unset runs in clearly labeled demo mode.
NEBIUS_API_KEY=
TAVILY_API_KEY=
COMPOSIO_API_KEY=

# Optional shared secret for POST /api/bank (header: X-MC-Token)
MC_BANK_TOKEN=

# The hunger ladder: which model the agent can afford at each wealth tier.
# Prices are USD per million tokens; set real numbers from the Nebius
# pricing page before a live run.
MC_MODEL_RICH=Qwen/Qwen3-235B-A22B
MC_PRICE_RICH_IN=0.20
MC_PRICE_RICH_OUT=0.60
MC_MODEL_HUNGRY=Qwen/Qwen3-30B-A3B
MC_PRICE_HUNGRY_IN=0.10
MC_PRICE_HUNGRY_OUT=0.30
MC_MODEL_STARVING=meta-llama/Llama-3.1-8B-Instruct
MC_PRICE_STARVING_IN=0.02
MC_PRICE_STARVING_OUT=0.06
